{
  "erb-linter.configPath": ".erb_lint.yml",
  "erb-linter.showErrorsInProblems": true,
  "erb-linter.enableLinting": true,
  "erb-linter.useBundler": false,
  "erb-linter.erbLintPath": "erb_lint",
  "files.associations": {
    "*.html.erb": "erb"
  },
  "emmet.includeLanguages": {
    "erb": "html"
  },
  "[erb]": {
    "editor.defaultFormatter": "manuelpuyol.erb-linter"
  }
}
